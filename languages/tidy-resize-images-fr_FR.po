#, php-format
msgid "Processed by Tidy on %s."
msgstr "Traité par Tidy le %s."

#: includes/class-media-library-hooks.php:147
msgid "Original is in the Tidy trash and can be restored."
msgstr "L'original se trouve dans la corbeille de Tidy et peut être restauré."

#. translators: 1: target MIME e.g. image/webp, 2: machine reason
#: includes/class-media-library-hooks.php:160
#, php-format
msgid "Tidy tried to convert this to %1$s but the result was no smaller (%2$s). It will be skipped on future runs unless settings change."
msgstr "Tidy a tenté de convertir cette valeur en %1$s, mais le résultat n'était pas plus court (%2$s). Elle sera ignorée lors des prochaines exécutions, sauf si les paramètres sont modifiés."

#: includes/class-media-library-hooks.php:165
msgid "Tidy will skip this attachment on future runs (a previous attempt produced no benefit)."
msgstr "Tidy ignorera cette pièce jointe lors des prochaines exécutions (une tentative précédente n'a donné aucun résultat)."

