#. Plugin Name of the plugin
#: tidy-resize-images.php
#: includes/class-admin-hooks.php:73
#: includes/class-media-library-hooks.php:436
msgid "Tidy Resize Images"
msgstr "Porządne skalowanie obrazów"

#. Plugin URI of the plugin
#: tidy-resize-images.php
msgid "https://github.com/headwalluk/tidy-resize-images"
msgstr "https://github.com/headwalluk/tidy-resize-images"

#. Description of the plugin
#: tidy-resize-images.php
msgid "Keep the WordPress Media Library lean. Resize oversized uploads, convert unsuitable formats, and recompress bloated files — with originals safely backed up to a Trash directory, dry-run preview, and full WP-CLI control."
msgstr "Dbaj o porządek w bibliotece multimediów WordPressa. Zmieniaj rozmiar zbyt dużych plików, konwertuj nieodpowiednie formaty i ponownie kompresuj nadmiernie rozbudowane pliki — a wszystko to przy bezpiecznej kopii zapasowej oryginałów w katalogu „Kosz”, podglądzie w trybie testowym i pełnej kontroli za pomocą WP-CLI."

#. Author of the plugin
#: tidy-resize-images.php
msgid "Paul Faulkner"
msgstr "Paul Faulkner"

#. Author URI of the plugin
#: tidy-resize-images.php
msgid "https://headwall-hosting.com/"
msgstr "https://headwall-hosting.com/"

#: admin-templates/bulk-page.php:24
#: admin-templates/trash-page.php:19
msgid "You do not have permission to view this page."
msgstr "Nie masz uprawnień do wyświetlenia tej strony."

#: admin-templates/bulk-page.php:37
#: includes/class-admin-hooks.php:96
msgid "Tidy Images — Bulk"
msgstr "Porządkowanie obrazów — zbiorczo"

#: admin-templates/bulk-page.php:42
msgid "Process existing attachments in your Media Library. The runner scans for image attachments that are not protected and have not previously been touched by this plugin, then resizes / converts / recompresses them according to your Settings."
msgstr "Przetwórz istniejące załączniki w bibliotece multimediów. Skrypt wyszukuje załączniki graficzne, które nie są chronione i nie zostały wcześniej przetworzone przez tę wtyczkę, a następnie zmienia ich rozmiar, konwertuje je lub ponownie kompresuje zgodnie z ustawieniami."

#: admin-templates/bulk-page.php:49
msgid "Before running:"
msgstr "Przed rozpoczęciem biegu:"

#: admin-templates/bulk-page.php:50
msgid "mark logos and brand artwork as \"do not touch\" (Media Library row action — landing in M8). Auto mode applies the same compression rules to every attachment regardless of visual sensitivity. Always run a dry-run first to preview decisions."
msgstr "Oznacz logo i grafiki związane z marką jako „nie dotykać” (operacja wiersza w bibliotece multimediów — przeniesienie do M8). Tryb automatyczny stosuje te same zasady kompresji do wszystkich załączników, niezależnie od ich wrażliwości wizualnej. Zawsze najpierw uruchom symulację, aby zapoznać się z wynikami."

#: admin-templates/bulk-page.php:61
msgid "Candidates ready to process:"
msgstr "Kandydaci gotowi do rozpatrzenia:"

#: admin-templates/bulk-page.php:63
msgid "Excludes attachments marked \"do not touch\" and those previously processed by this plugin."
msgstr "Z wyłączeniem załączników oznaczonych jako „nie dotykać” oraz tych, które zostały już przetworzone przez tę wtyczkę."

#: admin-templates/bulk-page.php:64
msgid "Dry-run setting:"
msgstr "Ustawienia testowe:"

#: admin-templates/bulk-page.php:65
msgid "on (use \"Run dry\" only)"
msgstr "włączone (używać wyłącznie opcji „Pracuj na sucho”)"

#: admin-templates/bulk-page.php:65
msgid "off"
msgstr "wyłączony"

#: admin-templates/bulk-page.php:66
msgid "Backup originals:"
msgstr "Oryginały kopii zapasowych:"

#: admin-templates/bulk-page.php:67
msgid "enabled"
msgstr "włączone"

#: admin-templates/bulk-page.php:67
msgid "disabled — modifications will be irreversible"
msgstr "nieaktywne — zmiany będą nieodwracalne"

#: admin-templates/bulk-page.php:79
msgid "Run dry (preview)"
msgstr "Odtwarzaj bez dźwięku (podgląd)"

#: admin-templates/bulk-page.php:80
msgid "Run live (modify files)"
msgstr "Uruchom na żywo (modyfikuj pliki)"

#: admin-templates/bulk-page.php:81
msgid "Stop"
msgstr "Stop"

#: admin-templates/bulk-page.php:101
msgid "Idle. Press a Run button to begin."
msgstr "Czeka w stanie spoczynku. Naciśnij przycisk „Uruchom”, aby rozpocząć."

#: admin-templates/bulk-page.php:102
msgid "Examined"
msgstr "Zbadano"

#: admin-templates/bulk-page.php:103
