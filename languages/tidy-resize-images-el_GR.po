#. Plugin Name of the plugin
#: tidy-resize-images.php
#: includes/class-admin-hooks.php:73
#: includes/class-media-library-hooks.php:436
msgid "Tidy Resize Images"
msgstr "Τακτοποίηση και αλλαγή μεγέθους εικόνων"

#. Plugin URI of the plugin
#: tidy-resize-images.php
msgid "https://github.com/headwalluk/tidy-resize-images"
msgstr "https://github.com/headwalluk/tidy-resize-images"

#. Description of the plugin
#: tidy-resize-images.php
msgid "Keep the WordPress Media Library lean. Resize oversized uploads, convert unsuitable formats, and recompress bloated files — with originals safely backed up to a Trash directory, dry-run preview, and full WP-CLI control."
msgstr "Διατηρήστε τη Βιβλιοθήκη πολυμέσων του WordPress ελαφριά. Αλλάξτε το μέγεθος των υπερμεγέθων αρχείων που έχετε ανεβάσει, μετατρέψτε τις ακατάλληλες μορφές και συμπιέστε εκ νέου τα φουσκωμένα αρχεία — με τα πρωτότυπα να αποθηκεύονται με ασφάλεια σε έναν κατάλογο «Κάδος απορριμμάτων», δοκιμαστική προεπισκόπηση και πλήρη έλεγχο μέσω WP-CLI."

#. Author of the plugin
#: tidy-resize-images.php
msgid "Paul Faulkner"
msgstr "Πολ Φόλκνερ"

#. Author URI of the plugin
#: tidy-resize-images.php
msgid "https://headwall-hosting.com/"
msgstr "https://headwall-hosting.com/"

#: admin-templates/bulk-page.php:24
#: admin-templates/trash-page.php:19
msgid "You do not have permission to view this page."
msgstr "Δεν έχετε δικαίωμα πρόσβασης σε αυτή τη σελίδα."

#: admin-templates/bulk-page.php:37
#: includes/class-admin-hooks.php:96
msgid "Tidy Images — Bulk"
msgstr "Τακτοποίηση εικόνων — Μαζικά"

#: admin-templates/bulk-page.php:42
msgid "Process existing attachments in your Media Library. The runner scans for image attachments that are not protected and have not previously been touched by this plugin, then resizes / converts / recompresses them according to your Settings."
msgstr "Επεξεργαστείτε τα υπάρχοντα συνημμένα στη Βιβλιοθήκη πολυμέσων σας. Το πρόγραμμα εκτελεί σάρωση για συνημμένα εικόνων που δεν είναι προστατευμένα και δεν έχουν υποστεί επεξεργασία από αυτό το πρόσθετο στο παρελθόν, και στη συνέχεια αλλάζει το μέγεθός τους / τα μετατρέπει / τα συμπιέζει εκ νέου σύμφωνα με τις Ρυθμίσεις σας."

#: admin-templates/bulk-page.php:49
msgid "Before running:"
msgstr "Πριν ξεκινήσετε:"

#: admin-templates/bulk-page.php:50
msgid "mark logos and brand artwork as \"do not touch\" (Media Library row action — landing in M8). Auto mode applies the same compression rules to every attachment regardless of visual sensitivity. Always run a dry-run first to preview decisions."
msgstr "Σημειώστε τα λογότυπα και τα γραφικά των εμπορικών σημάτων ως «μην αγγίζετε» (ενέργεια στη σειρά της Βιβλιοθήκης πολυμέσων — μεταφορά στο M8). Η αυτόματη λειτουργία εφαρμόζει τους ίδιους κανόνες συμπίεσης σε κάθε συνημμένο, ανεξάρτητα από την οπτική ευαισθησία του. Πάντα να εκτελείτε πρώτα μια δοκιμαστική εκτέλεση για να δείτε τις αποφάσεις."

#: admin-templates/bulk-page.php:61
msgid "Candidates ready to process:"
msgstr "Υποψήφιοι έτοιμοι για επεξεργασία:"

#: admin-templates/bulk-page.php:63
msgid "Excludes attachments marked \"do not touch\" and those previously processed by this plugin."
msgstr "Εξαιρούνται τα συνημμένα που φέρουν την ένδειξη «μην αγγίζετε» και εκείνα που έχουν ήδη υποβληθεί σε επεξεργασία από αυτό το πρόσθετο."

#: admin-templates/bulk-page.php:64
msgid "Dry-run setting:"
msgstr "Ρύθμιση δοκιμαστικής λειτουργίας:"

#: admin-templates/bulk-page.php:65
msgid "on (use \"Run dry\" only)"
msgstr "ενεργοποιημένο (χρησιμοποιήστε μόνο τη λειτουργία «Λειτουργία χωρίς νερό»)"

#: admin-templates/bulk-page.php:65
msgid "off"
msgstr "απενεργοποιημένο"

#: admin-templates/bulk-page.php:66
msgid "Backup originals:"
msgstr "Πρωτότυπα αντιγράφων ασφαλείας:"

#: admin-templates/bulk-page.php:67
msgid "enabled"
msgstr "ενεργοποιημένο"

#: admin-templates/bulk-page.php:67
msgid "disabled — modifications will be irreversible"
msgstr "απενεργοποιημένο — οι αλλαγές θα είναι μη αναστρέψιμες"

#: admin-templates/bulk-page.php:79
msgid "Run dry (preview)"
msgstr "Εκτέλεση χωρίς δεδομένα (προεπισκόπηση)"

#: admin-templates/bulk-page.php:80
msgid "Run live (modify files)"
msgstr "Εκτέλεση σε πραγματικό χρόνο (τροποποίηση αρχείων)"

#: admin-templates/bulk-page.php:81
msgid "Stop"
msgstr "Σταμάτα"

#: admin-templates/bulk-page.php:101
msgid "Idle. Press a Run button to begin."
msgstr "Σε αναμονή. Πατήστε ένα κουμπί «Εκτέλεση» για να ξεκινήσετε."

#: admin-templates/bulk-page.php:102
msgid "Examined"
msgstr "Εξετάστηκε"

#: admin-templates/bulk-page.php:103
msgid "Changed"
msgstr "Αλλαγή"

#: admin-templates/bulk-page.php:104
msgid "Skipped (planned / discarded / memo)"
msgstr "Παραλείφθηκε (προγραμματισμένο / απορρίφθηκε / σημείωση)"

#: admin-templates/bulk-page.php:105
msgid "Errored"
msgstr "Παρουσιάστηκε σφάλμα"

#: admin-templates/bulk-page.php:106
msgid "Bytes saved"
msgstr "Εξοικονόμηση byte"

#: admin-templates/bulk-page.php:123
msgid "Log"
msgstr "Αρχείο καταγραφής"

#: admin-templates/bulk-page.php:124
msgid "ID"
msgstr "Αριθμός ταυτοποίησης"

#: admin-templates/bulk-page.php:125
msgid "Title"
msgstr "Τίτλος"

#: admin-templates/bulk-page.php:126
msgid "Action"
msgstr "Δράση"

#: admin-templates/bulk-page.php:127
msgid "Reason"
msgstr "Λόγος"

#: admin-templates/bulk-page.php:128
#: admin-templates/trash-page.php:206
msgid "Saved"
msgstr "Αποθηκεύτηκε"

#: admin-templates/conflict-notice.php:26
msgid "Tidy Resize Images:"
msgstr "Τακτοποίηση και αλλαγή μεγέθους εικόνων:"

#: admin-templates/conflict-notice.php:27
msgid "detected the following image-optimization plugins active alongside this one. Running multiple image processors can cause unexpected behaviour. We will not deactivate them — your call."
msgstr "Εντοπίστηκαν τα ακόλουθα πρόσθετα βελτιστοποίησης εικόνων που λειτουργούν παράλληλα με αυτό. Η ταυτόχρονη χρήση πολλών επεξεργαστών εικόνων μπορεί να προκαλέσει απρόβλεπτη συμπεριφορά. Δεν θα τα απενεργοποιήσουμε — η απόφαση είναι δική σας."

#: admin-templates/conflict-notice.php:29
msgid "Visit Plugins to deactivate any that you no longer need."
msgstr "Μεταβείτε στην ενότητα «Πρόσθετα» για να απενεργοποιήσετε όποια δεν χρειάζεστε πλέον."

#: admin-templates/settings-page.php:24
#: admin-templates/settings-tabs/limits.php:25
msgid "Limits"
msgstr "Όρια"

#: admin-templates/settings-page.php:25
#: admin-templates/settings-tabs/format.php:96
msgid "Format"
msgstr "Μορφή"

#: admin-templates/settings-page.php:26
#: admin-templates/settings-tabs/behaviour.php:54
msgid "Behaviour"
msgstr "Συμπεριφορά"

#: admin-templates/settings-page.php:27
#: admin-templates/settings-tabs/status.php:78
msgid "Status"
msgstr "Κατάσταση"

#: admin-templates/settings-page.php:62
msgid "This tab is being built — content lands in a subsequent milestone."
msgstr "Αυτή η καρτέλα βρίσκεται υπό κατασκευή — το περιεχόμενο θα προστεθεί σε επόμενο στάδιο."

#: admin-templates/settings-page.php:86
msgid "Save Changes"
msgstr "Αποθήκευση αλλαγών"

#: admin-templates/settings-tabs/behaviour.php:55
msgid "Operational toggles that apply to every processing path (upload-time, bulk, WP-CLI)."
msgstr "Λειτουργικές επιλογές που ισχύουν για όλες τις μεθόδους επεξεργασίας (κατά τη μεταφόρτωση, μαζική επεξεργασία, WP-CLI)."

#: admin-templates/settings-tabs/behaviour.php:63
msgid "Dry-run mode"
msgstr "Λειτουργία δοκιμής"

#: admin-templates/settings-tabs/behaviour.php:66
msgid "Plan but do not modify anything"
msgstr "Σχεδιάστε, αλλά μην αλλάξετε τίποτα"

#: admin-templates/settings-tabs/behaviour.php:67
msgid "When enabled, every code path produces a report of what it would do without writing files or updating the database. Useful for previewing a bulk run before committing."
msgstr "Όταν είναι ενεργοποιημένη, κάθε διαδρομή κώδικα δημιουργεί μια αναφορά για το τι θα έκανε χωρίς να εγγράψει αρχεία ή να ενημερώσει τη βάση δεδομένων. Χρήσιμο για την προεπισκόπηση μιας μαζικής εκτέλεσης πριν από την οριστική εφαρμογή."

#: admin-templates/settings-tabs/behaviour.php:73
msgid "Strip EXIF metadata"
msgstr "Αφαίρεση μεταδεδομένων EXIF"

#: admin-templates/settings-tabs/behaviour.php:76
msgid "Remove EXIF / XMP / IPTC on encode"
msgstr "Αφαίρεση EXIF / XMP / IPTC κατά την κωδικοποίηση"

#: admin-templates/settings-tabs/behaviour.php:77
msgid "Drops camera metadata (timestamps, GPS, device info) and authoring metadata from re-encoded images. Recommended for public sites — modest size savings and removes accidental information disclosure."
msgstr "Αφαιρεί τα μεταδεδομένα της κάμερας (χρονοσημάνσεις, GPS, πληροφορίες συσκευής) και τα μεταδεδομένα δημιουργίας από τις επανακωδικοποιημένες εικόνες. Συνιστάται για δημόσιους ιστότοπους — προσφέρει μικρή εξοικονόμηση χώρου και αποτρέπει την τυχαία αποκάλυψη πληροφοριών."

#: admin-templates/settings-tabs/behaviour.php:83
msgid "Backup originals to Trash"
msgstr "Μετακίνηση των πρωτοτύπων στον Κάδο απορριμμάτων"

#: admin-templates/settings-tabs/behaviour.php:86
msgid "Keep a restorable copy of every modified original"
msgstr "Φυλάξτε ένα αντίγραφο κάθε τροποποιημένου αρχικού εγγράφου, το οποίο να μπορεί να αποκατασταθεί"

#: admin-templates/settings-tabs/behaviour.php:87
msgid "Originals are moved to wp-content/uploads/tri-trash/ and can be restored from the Trash admin page or via WP-CLI. Highly recommended — disabling this means modifications are irreversible."
msgstr "Τα αρχικά αρχεία μεταφέρονται στο φάκελο wp-content/uploads/tri-trash/ και μπορούν να επαναφερθούν από τη σελίδα διαχείρισης του Κάδου ή μέσω του WP-CLI. Συνιστάται ιδιαίτερα — αν απενεργοποιήσετε αυτή τη λειτουργία, οι αλλαγές θα είναι μη αναστρέψιμες."

#: admin-templates/settings-tabs/behaviour.php:94
msgid "Trash retention"
msgstr "Διατήρηση απορριμμάτων"

#: admin-templates/settings-tabs/behaviour.php:98
msgid "days"
msgstr "ημέρες"

#: admin-templates/settings-tabs/behaviour.php:99
msgid "Trashed originals are auto-purged after this many days. Set to 0 to disable auto-purge (purge manually only). The cron auto-purge lands in M10."
msgstr "Τα αρχεία που έχουν μεταφερθεί στον κάδο απορριμμάτων διαγράφονται αυτόματα μετά από τόσες ημέρες. Ορίστε την τιμή σε 0 για να απενεργοποιήσετε την αυτόματη διαγραφή (μόνο χειροκίνητη διαγραφή). Η αυτόματη διαγραφή μέσω cron θα ενεργοποιηθεί στην έκδοση M10."

#: admin-templates/settings-tabs/behaviour.php:119
msgid "Always skip these MIME types"
msgstr "Πάντα να παραλείπετε αυτούς τους τύπους MIME"

#: admin-templates/settings-tabs/behaviour.php:121
msgid "The image processor will refuse to touch sources of these MIME types regardless of other settings. Defaults: SVG and GIF (vector and animated formats are out of v1 scope)."
msgstr "Ο επεξεργαστής εικόνων δεν θα επεξεργάζεται αρχεία αυτών των τύπων MIME, ανεξάρτητα από άλλες ρυθμίσεις. Προεπιλογές: SVG και GIF (οι διανυσματικές και κινούμενες μορφές δεν εμπίπτουν στο πεδίο εφαρμογής της έκδοσης v1)."

#: admin-templates/settings-tabs/behaviour.php:131
msgid "rewrite raw + JSON-escaped URLs in post body content"
msgstr "αναδιαμόρφωση των URL σε μορφή raw και με διαφυγή JSON στο περιεχόμενο του σώματος της ανάρτησης"

#: admin-templates/settings-tabs/behaviour.php:134
msgid "rewrite serialised + JSON meta values (Elementor, ACF, etc.)"
msgstr "αναδιαμόρφωση σειριακών τιμών και τιμών μεταδεδομένων JSON (Elementor, ACF κ.λπ.)"

#: admin-templates/settings-tabs/behaviour.php:140
msgid "Search-replace scope"
msgstr "Πεδίο εφαρμογής της λειτουργίας «Αναζήτηση-αντικατάσταση»"

#: admin-templates/settings-tabs/behaviour.php:142
msgid "When the processor renames a file (e.g. PNG → WebP), references in these tables are rewritten. Disable a scope only if you know references will be updated by another mechanism. wp_options and multisite tables are out of v1 scope."
msgstr "Όταν ο επεξεργαστής μετονομάζει ένα αρχείο (π.χ. PNG → WebP), οι αναφορές σε αυτούς τους πίνακες αναπροσαρμόζονται. Απενεργοποιήστε ένα πεδίο εφαρμογής μόνο αν γνωρίζετε ότι οι αναφορές θα ενημερωθούν μέσω άλλου μηχανισμού. Οι πίνακες wp_options και multisite δεν εμπίπτουν στο πεδίο εφαρμογής της έκδοσης v1."

#: admin-templates/settings-tabs/format.php:75
msgid "not supported on this server"
msgstr "δεν υποστηρίζεται σε αυτόν τον διακομιστή"

#: admin-templates/settings-tabs/format.php:97
msgid "Choose the target format for converted and recompressed images. Simple/Auto mode is the only mode in v1 — Expert mode (a from→to mapping matrix) is planned."
msgstr "Επιλέξτε τη μορφή προορισμού για τις εικόνες που έχουν μετατραπεί και συμπιεστεί εκ νέου. Η λειτουργία «Απλή/Αυτόματη» είναι η μόνη διαθέσιμη λειτουργία στην έκδοση v1 — η λειτουργία «Για ειδικούς» (ένας πίνακας αντιστοίχισης «από»→«προς») βρίσκεται σε φάση σχεδιασμού."

#: admin-templates/settings-tabs/format.php:115
msgid "Lossy target format"
msgstr "Μορφή προορισμού με απώλειες"

#: admin-templates/settings-tabs/format.php:117
msgid "Used when converting PNG-without-alpha, HEIC, and static GIF. JPEG and WebP sources are always recompressed in place."
msgstr "Χρησιμοποιείται κατά τη μετατροπή αρχείων PNG χωρίς κανάλι αλφα, HEIC και στατικών GIF. Τα αρχεία JPEG και WebP υποβάλλονται πάντα σε επανασυμπίεση επί τόπου."

#: admin-templates/settings-tabs/format.php:124
msgid "Lossy quality"
msgstr "Ποιότητα με απώλειες"

#: admin-templates/settings-tabs/format.php:128
msgid "Encoder quality 1–100. Lower = smaller file, more visible artefacts."
msgstr "Ποιότητα κωδικοποιητή 1–100. Όσο χαμηλότερη τιμή, τόσο μικρότερο αρχείο, αλλά και περισσότερα ορατά ελαττώματα."

#: admin-templates/settings-tabs/format.php:144
msgid "Alpha-preserving target format"
msgstr "Μορφή προορισμού που διατηρεί τα χαρακτήρες άλφα"

#: admin-templates/settings-tabs/format.php:146
msgid "Used when the source has a meaningful alpha channel (PNG, AVIF, HEIC). Selecting \"PNG (keep)\" leaves alpha sources untouched."
msgstr "Χρησιμοποιείται όταν η πηγή διαθέτει κανάλι άλφα με ουσιαστικό περιεχόμενο (PNG, AVIF, HEIC). Εάν επιλέξετε «PNG (διατήρηση)», οι πηγές με κανάλι άλφα παραμένουν ως έχουν."

#: admin-templates/settings-tabs/format.php:153
msgid "Alpha-preserving quality"
msgstr "Ποιότητα που διατηρεί το άλφα"

#: admin-templates/settings-tabs/format.php:157
msgid "Encoder quality 1–100. Higher than lossy quality is recommended — alpha-bearing images are usually graphics where artefacts are more visible."
msgstr "Ποιότητα κωδικοποιητή 1–100. Συνιστάται ποιότητα υψηλότερη από την «με απώλειες» — οι εικόνες με διαφάνειες είναι συνήθως γραφικά στα οποία τα τεχνητά στοιχεία είναι πιο ορατά."

#: admin-templates/settings-tabs/format.php:164
msgid "JPEG recompression quality"
msgstr "Ποιότητα επανασυμπίεσης JPEG"

#: admin-templates/settings-tabs/format.php:168
msgid "Quality used when recompressing JPEG sources in place (no format change)."
msgstr "Ποιότητα που χρησιμοποιείται κατά την επί τόπου επανασυμπίεση αρχείων JPEG (χωρίς αλλαγή μορφής)."

#: admin-templates/settings-tabs/format.php:176
msgid "Expert mode"
msgstr "Λειτουργία για προχωρημένους"

#: admin-templates/settings-tabs/format.php:177
msgid "Coming soon."
msgstr "Σύντομα διαθέσιμο."

#: admin-templates/settings-tabs/format.php:178
msgid "Expert mode will replace the Simple/Auto decision tree with a from→to mapping matrix, so you can configure per-source-MIME outcomes (e.g. \"JPEG → AVIF for sources over 2 MB, otherwise recompress JPEG in place\"). Simple/Auto mode covers most use cases; Expert mode is for power users who want full control."
msgstr "Η λειτουργία «Expert» θα αντικαταστήσει το δέντρο αποφάσεων της λειτουργίας «Simple/Auto» με έναν πίνακα αντιστοίχισης «από→προς», ώστε να μπορείτε να ρυθμίσετε τα αποτελέσματα ανά πηγή και τύπο MIME (π.χ. «JPEG → AVIF για πηγές άνω των 2 MB, διαφορετικά επανασυμπίεση του αρχικού JPEG»). Η λειτουργία «Simple/Auto» καλύπτει τις περισσότερες περιπτώσεις χρήσης· η λειτουργία «Expert» προορίζεται για προχωρημένους χρήστες που επιθυμούν πλήρη έλεγχο."

#: admin-templates/settings-tabs/limits.php:26
msgid "Set the dimensional and file-size thresholds at which images become candidates for processing. These thresholds drive the bulk scanner — they are not enforced as caps on otherwise-good images."
msgstr "Ορίστε τα όρια διαστάσεων και μεγέθους αρχείου στα οποία οι εικόνες θεωρούνται υποψήφιες για επεξεργασία. Αυτά τα όρια καθοδηγούν τη μαζική σάρωση — δεν εφαρμόζονται ως ανώτατα όρια σε εικόνες που κατά τα άλλα είναι καλής ποιότητας."

#: admin-templates/settings-tabs/limits.php:35
msgid "Max longest edge"
msgstr "Μέγιστο μήκος ακμής"

#: admin-templates/settings-tabs/limits.php:39
msgid "pixels"
msgstr "εικονοστοιχεία"

#. translators: 1: min, 2: max
#: admin-templates/settings-tabs/limits.php:43
#, php-format
msgid "Images whose longest side exceeds this value are proportionally resized. Range: %1$d – %2$d px."
msgstr "Οι εικόνες των οποίων η μεγαλύτερη πλευρά υπερβαίνει αυτή την τιμή αλλάζουν αναλογικά το μέγεθός τους. Εύρος: %1$d – %2$d px."

#: admin-templates/settings-tabs/limits.php:55
msgid "Max file size"
msgstr "Μέγιστο μέγεθος αρχείου"

#: admin-templates/settings-tabs/limits.php:59
msgid "bytes"
msgstr "byte"

#. translators: 1: human-readable current value, 2: human-readable min, 3: human-readable max
#: admin-templates/settings-tabs/limits.php:63
#, php-format
msgid "Images larger than this become candidates for re-encoding. Current value: %1$s. Range: %2$s – %3$s."
msgstr "Οι εικόνες μεγαλύτερες από αυτό το μέγεθος ενδέχεται να υποβληθούν σε εκ νέου κωδικοποίηση. Τρέχουσα τιμή: %1$s. Εύρος: %2$s – %3$s."

#: admin-templates/settings-tabs/status.php:79
msgid "Read-only summary of capabilities, counts, and runtime debug values."
msgstr "Περίληψη μόνο για ανάγνωση σχετικά με τις δυνατότητες, τους αριθμούς και τις τιμές εντοπισμού σφαλμάτων κατά την εκτέλεση."

#: admin-templates/settings-tabs/status.php:85
msgid "No processing has run on this site yet. Counts below will populate once the upload handler (M5) or bulk processor (M7) start touching attachments."
msgstr "Δεν έχει πραγματοποιηθεί ακόμη καμία επεξεργασία σε αυτόν τον ιστότοπο. Οι παρακάτω μετρήσεις θα εμφανιστούν μόλις ο χειριστής μεταφόρτωσης (M5) ή ο επεξεργαστής μαζικής επεξεργασίας (M7) αρχίσει να επεξεργάζεται τα συνημμένα."

#: admin-templates/settings-tabs/status.php:92
msgid "Backends"
msgstr "Backends"

#: admin-templates/settings-tabs/status.php:120
msgid "MIME type"
msgstr "Τύπος MIME"

#: admin-templates/settings-tabs/status.php:121
msgid "GD"
msgstr "Καλημέρα"

#: admin-templates/settings-tabs/status.php:122
msgid "Imagick"
msgstr "Imagick"

#: admin-templates/settings-tabs/status.php:130
msgid "Counts"
msgstr "Αριθμοί"

#: admin-templates/settings-tabs/status.php:139
msgid "Total attachments"
msgstr "Σύνολο συνημμένων"

#: admin-templates/settings-tabs/status.php:141
msgid "Processed by Tidy Images"
