msgstr "Non disponi dei permessi necessari per eseguire questa operazione."

#: includes/class-admin-hooks.php:300
#: includes/class-media-library-hooks.php:246
msgid "Missing attachment ID."
msgstr "Manca l'ID dell'allegato."

#: includes/class-admin-hooks.php:306
msgid "Security check failed. Refresh the Trash page and try again."
msgstr "Controllo di sicurezza non riuscito. Aggiorna la pagina \"Cestino\" e riprova."

#: includes/class-admin-hooks.php:358
msgid "Starting…"
msgstr "Si parte…"

#: includes/class-admin-hooks.php:359
msgid "Processing…"
msgstr "Elaborazione in corso…"

#: includes/class-admin-hooks.php:360
msgid "Done."
msgstr "Fatto."

#: includes/class-admin-hooks.php:361
