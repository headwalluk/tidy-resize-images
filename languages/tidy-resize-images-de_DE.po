#. Plugin Name of the plugin
#: tidy-resize-images.php
#: includes/class-admin-hooks.php:73
#: includes/class-media-library-hooks.php:436
msgid "Tidy Resize Images"
msgstr "Bilder übersichtlich in der Größe anpassen"

#. Plugin URI of the plugin
#: tidy-resize-images.php
msgid "https://github.com/headwalluk/tidy-resize-images"
msgstr "https://github.com/headwalluk/tidy-resize-images"

#. Description of the plugin
#: tidy-resize-images.php
msgid "Keep the WordPress Media Library lean. Resize oversized uploads, convert unsuitable formats, and recompress bloated files — with originals safely backed up to a Trash directory, dry-run preview, and full WP-CLI control."
msgstr "Halten Sie die WordPress-Medienbibliothek schlank. Passen Sie die Größe übergroßer Uploads an, konvertieren Sie ungeeignete Formate und komprimieren Sie überladene Dateien neu – wobei die Originale sicher in einem Papierkorb-Verzeichnis gesichert werden, eine Vorschau im Testmodus verfügbar ist und Sie die volle Kontrolle über WP-CLI haben."

#. Author of the plugin
#: tidy-resize-images.php
msgid "Paul Faulkner"
msgstr "Paul Faulkner"

#. Author URI of the plugin
#: tidy-resize-images.php
msgid "https://headwall-hosting.com/"
msgstr "https://headwall-hosting.com/"

